# DSN do bazy Postgres uzywanej przez repozytoria pipeline i dashboard.
POSTGRES_DSN=postgresql+psycopg://leadpipe:leadpipe_change_me@127.0.0.1:5432/leadpipe

# Adres Redis dla kolejek RQ, statusow jobow i retry.
REDIS_URL=redis://127.0.0.1:6379/0

# Klucz API do OpenCode Go / Kimi K2.5 vision uzywany przez warstwe T2.
OPENCODE_GO_API_KEY=

# Bazowy endpoint OpenCode Go zgodny z OpenAI API.
OPENCODE_GO_BASE_URL=https://opencode.ai/zen/go/v1

# Dzienny limit kosztu T2 w USD; po przekroczeniu T2 ma byc wstrzymane.
T2_DAILY_BUDGET=5

# Szacowany koszt pojedynczego wywolania T2 w USD do liczenia budzetu.
T2_COST_PER_CALL=0.02

# Punkt montowania zasobu GCS / hermes-free na VM.
GCS_MOUNT=/mnt/hermes-free

# Glowny katalog danych pipeline: importy, eksporty, snapshoty, logi i raporty.
PIPELINE_DATA_DIR=/mnt/hermes-free/lead-pipeline

# User-Agent dla skanowania stron; zawiera kontakt operacyjny i opis celu audytu.
USER_AGENT=MeNETLeadScanner/1.0 (+kontakt@menet.pl; B2B site audit)
